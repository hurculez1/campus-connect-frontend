{
  "name": "campus-connect",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "CI=false npm run build",
  "rewrites": [
    { "source": "/admin_login", "destination": "/index.html" },
    { "source": "/admin-login", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/*", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
