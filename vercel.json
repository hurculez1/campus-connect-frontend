{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "CI=false npm run build",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin_login", "dest": "/index.html" },
    { "src": "/admin-login", "dest": "/index.html" },
    { "src": "/admin", "dest": "/index.html" },
    { "src": "/admin/.*", "dest": "/index.html" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
